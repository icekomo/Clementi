<section id="contact-overlay">
    <div id="contact-panel">

        <button id="close-btn">Close</button>

        <h1>Contact Us</h1>
        <p>Our expert team would love to help your company succeed. Don't wait for the moment —  Make it!</p>
        <ul>
            <li><a href="#"></a>+1 (610) 527-2600</li>
            <li><a href="#"></a>info@regulatoryaffairs.com </li>
            <li><a href="#"></a>Get Directions</li>
        </ul>

        <section>
            <h2>Request a Consultation</h2>
            <p>Fill out our contact form and one of our experts will reach out to you shortly.</p>
        </section>

        <section>
            <h2>How Can We Help?</h2>
            <form>
            <fieldset>
                <legend>Name <span>*</span></legend>
                <div>
                <input type="text" id="first-name" name="first_name" required>
                <label for="first-name">First</label>
                </div>
                <div>
                <input type="text" id="last-name" name="last_name" required>
                <label for="last-name">Last</label>
                </div>
            </fieldset>

            <div>
                <label for="company">Company</label>
                <input type="text" id="company" name="company">
            </div>

            <fieldset>
                <legend>Email <span>*</span></legend>
                <div>
                <input type="email" id="enter-email" name="email" placeholder="Enter Email" required>
                <label for="enter-email">Enter Email</label>
                </div>
                <div>
                <input type="email" id="confirm-email" name="confirm_email" placeholder="Confirm Email" required>
                <label for="confirm-email">Confirm Email</label>
                </div>
            </fieldset>

            <div>
                <label for="phone">Phone <span>*</span></label>
                <input type="tel" id="phone" name="phone" required>
            </div>

            <fieldset>
                <legend>Reason <span>*</span></legend>
                <div>
                <input type="checkbox" id="rfp" name="reason" value="request_for_proposal">
                <label for="rfp">Request for Proposal</label>
                </div>
                <div>
                <input type="checkbox" id="rfc" name="reason" value="request_for_consultation">
                <label for="rfc">Request for Consultation</label>
                </div>
                <div>
                <input type="checkbox" id="general" name="reason" value="general_inquiry">
                <label for="general">General Inquiry</label>
                </div>
            </fieldset>

            <div>
                <label for="comments">Comments & Inquiries <span>*</span></label>
                <textarea id="comments" name="comments" required></textarea>
            </div>

            <button type="submit">Submit</button>
</form>
        </section>
    </div>
</section>