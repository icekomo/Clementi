<section id="contact" class="content-padding">
    <div>
        <section id="contact-header">
            <div id="gus-contact">
                <img src="img/contact/gus-contact.svg" alt="Gus saying hello">
            </div>
            <div>
                <h1>Say hi to Gus!</h1>
                <article>
                    <p>Have an idea for an update or improvement?</p>
                    <p>We'd <span><i class="fa-solid fa-heart"></i></span> to hear from you! Send Gus an email with your suggestions.</p>
                </article>
            </div>
            
        </section>
        <form
        action="https://formspree.io/f/xrbywqbo"
        class="fs-form"
        target="_top"
        method="POST"
        >
            <div class="fs-field form-block">
                <input class="fs-input" id="name" name="name" required  placeholder="Your Name"/>
            </div>
            <div class="fs-field form-block">
                <input class="fs-input" id="email" name="email" required placeholder="Email"/>
            </div>
            <div class="fs-field form-block">
                <textarea
                class="fs-textarea"
                id="message"
                name="message"
                required
                placeholder="Message"
                ></textarea>
            </div>
            <div class="fs-button-group">
                <button class="fs-button" type="submit">Submit</button>
            </div>
        </form>
    </div>
</section>