<section id="new" class="content-padding">
    <div>
        <section>
            <h1>What's <span>NEW</span> this time?</h1>
            <p>You gussed it...<span>EVERYTHING!</span></p>
        </section>
        <ul id="new-grid">
            <li id="multi" class="new-items">
                <section>
                    <img src="img/new/multi.png" alt="multi devices">   
                </section>
                <article>
                    <h2>Cross platform access!</h2>
                    <p>Possibly the most requeasted feature for owed+. You can now use owed+ on any device signed in with your Apple ID—<span>no logins or passwords required.</span></p>
                </article> 
            </li>

            <li id="interface" class="new-items">
                <section>
                    <!-- <img src="img/new/interface.svg" alt="new UI">  -->
                    <!-- @import "new-interface.kit" -->
                </section>
                <article>
                    <h2>Redesigned UI</h2>
                    <p>The redesigned interface puts all your important information front and center—view details about any person or note instantly.</p>
                </article>
            </li>

            <li id="colors" class="new-items">
                 <section>
                    <img src="img/new/colors.svg" alt="color pallet">   
                </section>
                <article>
                    <h2>New Colors</h2>
                    <p>Colors have been carefully refined to deliver a high-contrast palette, improving readability and user experience.</p>
                </article>
            </li>

            <li id="gus" class="new-items">
                 <section>
                    <!-- <img src="img/new/gus-flying.svg" alt="Gus flying">   -->
                     <!-- @import "new-gus.kit" --> 
                </section>
                <article>
                    <h2>Meet Gus!</h2>
                    <p>Say hello to Gus, our friendly mascot! Gus is here to help new users get started with the app.</p>
                </article>
            </li>

             <li id="chat" class="new-items">
                <section>
                    <div>
                        <img src="img/new/chat.svg" alt="chat-icon">   
                    </div>
                </section>
                <article>
                    <h2>Texting that helps you!</h2>
                    <p>Request money seamlessly through Apple Pay, Venmo, PayPal, with more options coming in future updates. Payment requests are sent via text message (standard text rates apply)."</p>
                </article>     
            </li>

             <li id="icons" class="new-items">
                <section id="icon-parent">
                    <ul id="icon-container">
                        <li id="icon-1" class="icon"></li>
                        <li id="icon-2" class="icon"></li>
                        <li id="icon-3" class="icon"></li>
                        <li id="icon-4" class="icon"></li>
                        <li id="icon-5" class="icon"></li>
                    </ul>
                </section>
                <article>
                    <h2>Custom Icons</h2>
                    <p>owed+ lets you customize your app icon. This feature also encourages Gus to create and release more custom icons in the future!</p>
                </article>  
            </li>
        </ul>
    </div>
</section>