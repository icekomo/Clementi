<section id="services" class="content-padding">
    <div id="services-container">
        <h1 class="content-title">Key Services</h1>
        <ul id="service-card-container">
            <li class="service-card">
                <div class="service-img" id="service-card-1">
                    <img src="img/service/rx-icon.svg" alt="RX icon" />
                </div>
                <article>
                    <h2>FDA Submissions</h2>
                    <p>
                        We provide end-to-end support for regulatory
                        submissions.
                    </p>
                    <ul id="fda-list">
                        <li>
                            <i class="fa-solid fa-circle-check"></i>Pre-IND and
                            INTERACT meetings
                        </li>
                        <li>
                            <i class="fa-solid fa-circle-check"></i>IND
                            applications
                        </li>
                        <li>
                            <i class="fa-solid fa-circle-check"></i>NDA and BLA
                            Submissions
                        </li>
                        <li>
                            <i class="fa-solid fa-circle-check"></i>Amendments,
                            Supplements, & Annual reports
                        </li>
                    </ul>
                </article>
            </li>

            <li class="service-card">
                <div class="service-img" id="service-card-2">
                    <img src="img/service/doc-icon.svg" alt="RX icon" />
                </div>
                <article>
                    <h2>Document Management</h2>
                    <ul id="doc-list">
                        <li><i class="fa-solid fa-circle-check"></i>Maintenance of Full Regulatory History</li>
                        <li><i class="fa-solid fa-circle-check"></i>Manage ESG Client Accounts</li>
                        <li>
                            <i class="fa-solid fa-circle-check"></i>Secure Cloud Project, Workflows, and Task Manager
                        </li>
                        <li><i class="fa-solid fa-circle-check"></i>Current XML eCTD Publisher and Validator</li>
                        <li>
                            <i class="fa-solid fa-circle-check"></i>Preparation of Submission-Ready Compliant Documents
                        </li>
                        <li><i class="fa-solid fa-circle-check"></i>Document Management System (Cloud and Premises)</li>
                        <li><i class="fa-solid fa-circle-check"></i>Off-site Multiple Backup Systems (Cloud)</li>
                    </ul>
                </article>
            </li>

            <li class="service-card">
                <div class="service-img" id="service-card-3">
                    <img src="img/service/therapy-icon.svg" alt="therapy icon" />
                </div>
                <article>
                    <h2>CMC Development</h2>
                    <p>
                        We support Chemistry, Manufacturing, and Controls (CMC)
                        development for complex biologics and cell-based
                        products.
                    </p>
                    <ul id="cmc-list">
                        <li><i class="fa-solid fa-circle-check"></i>Process development and scale-up</li>
                        <li><i class="fa-solid fa-circle-check"></i>Analytical method developmentns</li>
                        <li><i class="fa-solid fa-circle-check"></i>Stability programs</li>
                        <li><i class="fa-solid fa-circle-check"></i>CMC documentation for IND/BLA</li>
                    </ul>
                </article>
            </li>

            <li class="service-card">
                <div class="service-img" id="service-card-4">
                    <img src="img/service/cmc-icon.svg" alt="cmc icon" />
                </div>
                <article>
                    <h2>Advanced Therapies</h2>
                    <p>Specialized support for cutting-edge therapeutics.</p>
                    <ul id="therapy-list">
                        <li><i class="fa-solid fa-circle-check"></i>Cell and gene therapy products</li>
                        <li><i class="fa-solid fa-circle-check"></i>ATMP regulatory strategy</li>
                        <li><i class="fa-solid fa-circle-check"></i>Comparability and potency assays</li>
                        <li><i class="fa-solid fa-circle-check"></i>Vector manufacturing and control strategies</li>
                        <li><i class="fa-solid fa-circle-check"></i>Document Management</li>
                    </ul>
                </article>
            </li>

            <li class="service-card">
                <h2>FDA Submissions</h2>
            </li>
        </ul>
    </div>
</section>
